# Core
NODE_ENV=development
APP_URL=http://localhost:3000
LOG_LEVEL=info

# Auth.js
AUTH_SECRET=                      # openssl rand -base64 48
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Database (Railway Postgres in prod; docker-compose locally)
DATABASE_URL=postgresql://zelyo:zelyo@localhost:5432/zelyo?schema=public
DIRECT_URL=postgresql://zelyo:zelyo@localhost:5432/zelyo?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Object storage (dev=MinIO, prod=Railway bucket; S3 API)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=zelyo
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Stellar / Soroban (testnet)
STELLAR_NETWORK=testnet
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
ISSUER_SECRET=                    # S... server-only signer for set_root + deploy. NEVER expose to client
CREDENTIAL_REGISTRY_CONTRACT_ID=
VERIFIER_CONTRACT_ID=

# ZK
ZK_SCOPE_APP_ID=zelyo-v1          # folded into scope = Hash(app_id|chain_id|registry_id)
ZK_VERIFY_MODE=server             # onchain (Path A) | server (Path B). Set by the Phase 0 decision gate.
CIRCUIT_ARTIFACT_BASE=/circuit    # served from apps/web/public/circuit

# SEP-10 web authentication
SEP10_HOME_DOMAIN=localhost:3000
SEP10_SIGNER_SECRET=                             # S... server-only signer for SEP-10 challenges
SEP10_CHALLENGE_TTL_SECONDS=300
SEP10_JWT_MAX_AGE_SECONDS=900
SEP10_JWT_SECRET=                                # optional; falls back to AUTH_SECRET

# Passkey-kit smart wallets (client config)
NEXT_PUBLIC_PASSKEY_KIT_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_PASSKEY_KIT_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NEXT_PUBLIC_PASSKEY_KIT_WALLET_WASM_HASH=        # passkey-kit wallet factory WASM hash

# OpenZeppelin Stellar Channels fee sponsorship (optional; testnet API key from https://channels.openzeppelin.com/testnet/gen)
USE_CHANNELS=false
CHANNELS_URL=https://channels.openzeppelin.com/testnet
CHANNELS_API_KEY=                               # API key from OpenZeppelin Stellar Channels

# SEP-38 anchor RFQ (indicative prices + firm quotes for fiat/crypto conversion).
# Leave unset to disable the SEP-38 endpoints (the service throws SEP38_NOT_CONFIGURED).
# Example test anchor: https://testanchor.stellar.org
SEP38_ANCHOR_URL=                               # anchor base URL hosting the SEP-38 API
SEP38_API_KEY=                                  # bearer token for firm quotes (POST /quote)

# Feature gates (client-readable)
NEXT_PUBLIC_SEP45_ENABLED=false

# Seed (admin + issuer)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                    # strong; set per environment
ISSUER_NAME=Institute of Distributed Systems
ISSUER_STELLAR_ACCOUNT=

# Public (non-secret client config only)
NEXT_PUBLIC_EXPLORER_BASE=https://stellar.expert/explorer/testnet
